DATABASE_NAME=giftgenius_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres123
DATABASE_HOST=localhost
DATABASE_PORT=5433

# Platform cut kept on every sale; the remainder is owed to the vendor.
PLATFORM_COMMISSION_PERCENT=15

# --- M-Pesa (Safaricom Daraja) ------------------------------------------
# sandbox | production - swap this plus every value below to go live.
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=REPLACE_WITH_YOUR_DARAJA_CONSUMER_KEY
MPESA_CONSUMER_SECRET=REPLACE_WITH_YOUR_DARAJA_CONSUMER_SECRET
# Sandbox default test shortcode (Lipa Na M-Pesa Online):
MPESA_SHORTCODE=174379
MPESA_PASSKEY=REPLACE_WITH_YOUR_DARAJA_PASSKEY
# Public HTTPS URL Safaricom calls with the STK push result.
# Run tools/start-ngrok.bat, copy the printed https forwarding URL, paste
# it here ending in /api/payments/mpesa/callback/, then restart the backend.
MPESA_CALLBACK_URL=https://REPLACE-WITH-YOUR-NGROK-URL.ngrok-free.app/api/payments/mpesa/callback/

# B2C (vendor payouts) - separate Daraja sandbox app/credentials.
MPESA_INITIATOR_NAME=REPLACE_WITH_YOUR_INITIATOR_NAME
MPESA_INITIATOR_PASSWORD=REPLACE_WITH_YOUR_INITIATOR_PASSWORD
MPESA_CERT_PATH=payments/certs/sandbox_cert.cer
MPESA_B2C_RESULT_URL=https://REPLACE-WITH-YOUR-NGROK-URL.ngrok-free.app/api/payments/mpesa/b2c-result/
MPESA_B2C_TIMEOUT_URL=https://REPLACE-WITH-YOUR-NGROK-URL.ngrok-free.app/api/payments/mpesa/b2c-timeout/

# --- PayPal --------------------------------------------------------------
# sandbox | live - swap this plus the client id/secret to go live.
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=ATnLFhUO2CjydEvBeyGK22JUFv0ovWhPQIXj9F5amOwCbRRX7h4CCOe-swwbqEZfgI3gsGUT84eKZIhV
PAYPAL_CLIENT_SECRET=EP_PP-ejThUEGTNXq9lqi0K2f-WrrItZaP8sL-wOL8s_StAAuvjNRWvRKCw6Lg8lPxLf6DvIB42vzR4s
PAYPAL_CURRENCY=USD
# Static KSh -> USD approximation used only to size the PayPal charge/payout.
KES_TO_USD_RATE=0.0078
